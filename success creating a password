# password stuff

print ("Please enter a password to secure your account.")

while True:
  password = input("\nEnter your secure password: ")
  
  number = False
  symbol = False
  length = False
  
  if len(password) >= 8:
      length = True
  
  
  for char in password:
      if char.isdigit():
          number = True
      if not char.isalpha() and not char.isdigit():
          symbol = True
          
  if not length:
      print("\nWeak password! Password must be at least eight letters long.")       
  elif not number and not symbol:
      print("\nWeak password! You must include at least one symbol and one number.")   
  elif not number:
      print("\nWeak password! You must include at least one number.")
  elif not symbol:
      print("\nWeak password! You must include at least one symbol.")
  else:
          print("\nPassword strength approved.")
          break
          
          
          
while True:
  print("\nPlease confirm your password.")
  password2 = input("\nConfirm password: ")
  
  
  if password2 == password:
          print("\nPassword set.")
          break
  else:
          print("\nPassword doesn't match.")
          
          
          
  
          
  
       
